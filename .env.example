# MedicalStore Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ─── Database Configuration ────────────────────────────────────────────────
DB_URL=jdbc:mysql://your-database-host:3306/medicalstore_db?useSSL=true&requireSSL=true&serverTimezone=UTC
DB_USERNAME=your_database_username
DB_PASSWORD=your_database_password

# ─── Twilio WhatsApp Configuration ─────────────────────────────────────────
# Get credentials from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+14155238886
TWILIO_WHATSAPP_ENABLED=false

# ─── Security ──────────────────────────────────────────────────────────────
# Generate a strong random key for remember-me functionality
REMEMBER_ME_KEY=change_this_to_a_random_string_in_production

# ─── Application Settings ──────────────────────────────────────────────────
SERVER_PORT=8081
