<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Invoice - Medical Store</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        @media print { .no-print { display: none; } body { margin: 0; } }
        .invoice-container { max-width: 800px; margin: 20px auto; padding: 30px; border: 2px solid #333; }
        .invoice-header { text-align: center; border-bottom: 3px solid #667eea; padding-bottom: 20px; margin-bottom: 30px; }
        .invoice-header h1 { color: #667eea; font-weight: bold; margin-bottom: 5px; }
        .invoice-details { display: flex; justify-content: space-between; margin-bottom: 30px; }
        .invoice-table { margin: 30px 0; }
        .invoice-table th { background-color: #667eea; color: white; }
        .invoice-footer { margin-top: 50px; text-align: center; border-top: 2px solid #ddd; padding-top: 20px; }
        .total-section { background-color: #f8f9fa; padding: 15px; border-radius: 5px; margin-top: 20px; }
    </style>
</head>
<body>
    <div class="invoice-container">
        <!-- Header -->
        <div class="invoice-header">
            <h1><i class="bi bi-heart-pulse"></i> ${companyName}</h1>
            <p class="mb-0">${companyAddress}</p>
            <p class="mb-0">Phone: ${companyPhone} | Email: ${companyEmail}</p>
            <p class="mb-0"><strong>GSTIN: ${companyGstin}</strong></p>
        </div>

        <!-- Invoice Details -->
        <div class="invoice-details">
            <div>
                <h5>BILL TO:</h5>
                <p class="mb-1"><strong>${customerName}</strong></p>
                #if($customerPhone && $customerPhone != "")
                <p class="mb-1">Phone: ${customerPhone}</p>
                #end
                #if($customerAddress && $customerAddress != "")
                <p class="mb-1">${customerAddress}</p>
                #end
            </div>
            <div class="text-end">
                <h5>INVOICE DETAILS:</h5>
                <p class="mb-1"><strong>Invoice #:</strong> ${invoiceNumber}</p>
                <p class="mb-1"><strong>Date:</strong> ${saleDate}</p>
                <p class="mb-1"><strong>Time:</strong> ${saleTime}</p>
            </div>
        </div>

        <!-- Items Table -->
        <table class="table table-bordered invoice-table">
            <thead>
                <tr>
                    <th>Sr. No.</th>
                    <th>Medicine Name</th>
                    <th>Batch No.</th>
                    <th>Quantity</th>
                    <th>Unit Price</th>
                    <th>Total</th>
                </tr>
            </thead>
            <tbody>
                #foreach($item in $items)
                <tr>
                    <td>$foreach.count</td>
                    <td>
                        <strong>${item.medicineName}</strong><br>
                        <small class="text-muted">${item.category}</small>
                    </td>
                    <td>${item.batchNumber}</td>
                    <td>${item.quantity}</td>
                    <td>&#8377;${item.unitPrice}</td>
                    <td>&#8377;${item.totalPrice}</td>
                </tr>
                #end
            </tbody>
        </table>

        <!-- Total Section -->
        <div class="total-section">
            <div class="row">
                <div class="col-8 text-end"><h5>Subtotal:</h5></div>
                <div class="col-4 text-end"><h5>&#8377;${subtotal}</h5></div>
            </div>
            #if($discountPercentage > 0)
            <div class="row">
                <div class="col-8 text-end"><h5>Discount (${discountPercentage}%):</h5></div>
                <div class="col-4 text-end"><h5 class="text-danger">- &#8377;${discountAmount}</h5></div>
            </div>
            #end
            #if($gstPercentage > 0)
            <div class="row">
                <div class="col-8 text-end"><h5>GST (${gstPercentage}%):</h5></div>
                <div class="col-4 text-end"><h5 class="text-success">+ &#8377;${gstAmount}</h5></div>
            </div>
            #end
            <hr>
            <div class="row">
                <div class="col-8 text-end"><h4><strong>GRAND TOTAL:</strong></h4></div>
                <div class="col-4 text-end"><h4><strong>&#8377;${grandTotal}</strong></h4></div>
            </div>
            <div class="row mt-2">
                <div class="col-12 text-end">
                    <span class="badge bg-success">Payment: ${paymentMethod}</span>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <div class="invoice-header" style="border-bottom:none; border-top: 2px solid #ddd; padding-top: 20px; text-align: center; margin-top: 50px;">
            <p class="mb-2"><strong>Terms &amp; Conditions:</strong></p>
            <p class="small mb-1">1. Goods are eligible for return only with original invoice</p>
            <p class="small mb-1">2. All disputes subject to local jurisdiction only</p>
            <p class="small mb-4">3. Please check the medicine expiry date before use</p>
            <p class="mb-0"><strong>Thank you for your business!</strong></p>
            <p class="small text-muted">Generated on ${generatedDate}</p>
        </div>

        <!-- Action Buttons -->
        <div class="text-center mt-4 no-print">
            <a href="/sales/pdf/${saleId}" class="btn btn-danger btn-lg me-2">
                <i class="bi bi-file-pdf"></i> Download PDF
            </a>
            <button onclick="window.print()" class="btn btn-primary btn-lg me-2">
                <i class="bi bi-printer"></i> Print Invoice
            </button>
            <a href="/sales" class="btn btn-secondary btn-lg">
                <i class="bi bi-arrow-left"></i> Back to Sales
            </a>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
